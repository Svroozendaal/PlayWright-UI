{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "tsBuildInfoFile": "./out/tsbuild/web.tsbuildinfo"
  },
  "include": [
    "src/renderer/src/**/*",
    "src/shared/**/*"
  ]
}
