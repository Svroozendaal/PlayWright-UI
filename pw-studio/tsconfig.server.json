{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./out/tsbuild/server.tsbuildinfo"
  },
  "include": [
    "src/server/**/*",
    "src/shared/**/*"
  ]
}
